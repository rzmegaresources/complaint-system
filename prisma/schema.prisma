// ============================================================
// FYP Complaint System - Database Schema
// AI-Powered Complaint Management with RAG Support
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  USER
  STAFF
  HR
}

enum Status {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================
// MODELS
// ============================================================

model User {
  id        Int       @id @default(autoincrement())
  loginId   String    @unique           // Alphanumeric login ID (e.g. JD01, HR01, AD01)
  password  String    @default("123456") // Plain text for demo purposes
  email     String    @unique
  name      String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  tickets    Ticket[]
  messages   Message[]
  feedbacks  Feedback[]
  petitions  Petition[]

  @@map("users")
}

model Ticket {
  id          Int       @id @default(autoincrement())
  ticketCode  String?   @unique   // Auto-generated: C00001-C99999
  title       String
  description String    @db.Text
  status      Status    @default(OPEN)
  priority    Priority  @default(MEDIUM)
  category    String?
  location    String?
  imageUrl    String?   // Path to uploaded complaint image
  latitude    Float?    // Map pin latitude
  longitude   Float?    // Map pin longitude
  aiAnalysis  Json?     // Stores AI-generated tags, sentiment, category suggestions
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("tickets")
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  createdAt DateTime @default(now())

  // Relations
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderId  Int
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@map("messages")
}

model Document {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  metadata  Json     // Stores source file name, page number, chunk index
  embedding Unsupported("vector(768)") // Gemini embedding dimension
  createdAt DateTime @default(now())

  @@map("documents")
}

model Feedback {
  id           Int      @id @default(autoincrement())
  feedbackCode String?  @unique   // Auto-generated: F00001-F99999
  type         String   // "staff", "facility", "service", "recommendation", "other"
  target       String?  // Who/what the feedback is about
  rating    Int?     // 1-5 star rating (optional)
  comment   String   @db.Text
  createdAt DateTime @default(now())

  // Relations
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("feedbacks")
}

model Petition {
  id           Int      @id @default(autoincrement())
  petitionCode String?  @unique   // Auto-generated: P00001-P99999
  title        String
  description  String   @db.Text
  category     String?
  votes       Int      @default(1)
  voterIds    Json     @default("[]") // Array of user IDs who voted
  status      String   @default("active") // "active" or "closed"
  createdAt   DateTime @default(now())

  // Relations
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("petitions")
}
